%post

# Install and update OS packages
  apt-get -y update
  apt-get -y upgrade
  apt-get -y install build-essential
  apt-get -y clean

  git clone https://github.com/stan-dev/cmdstan.git --recursive \
  && cd cmdstan && make -j4 build

# R variables

  export AWS_DEFAULT_REGION=''
  export CRAN=${CRAN:-https://cloud.r-project.org/}
  export TZ=Europe/Helsinki

# Install R packages
  Rscript -e 'install.packages("opt/tarballs/superMICE_1.1.1.tar.gz", repos = NULL, type = "source")'
  Rscript -e 'install.packages("cmdstanr", repos = c("https://stan-dev.r-universe.dev", getOption("repos")))'
  Rscript -e 'install.packages("rstan", repos = c("https://stan-dev.r-universe.dev", getOption("repos")))'
  Rscript -e 'install.packages(c("posterior","bayesplot","sjPlot","brms","ctsem"))'
  Rscript -e 'install.packages(c("lme4","survival","dHSIC","glmmTMB","glmnet","grpnet","pammtools","survPen", "nlme"))'
  Rscript -e 'install.packages(c("lavaan","nFactors","mirt","cvsem","GPArotations","corrplot","rstiefel"))'
  Rscript -e 'install.packages(c("psych","semTools","writexl","blavaan","nortest","qgraph","viridis","patchwork"))'
  Rscript -e 'install.packages(c("rang","pryr","fastmatrix","doParallel","cvAUC","fastDummies","stdReg","splitstackshape","splitTools","superml"))'
  Rscript -e 'install.packages(c("ggpubr","predictABEL","pROC","SnowballC","stopwords","textcat","textmineR","tokenizers"))'
  Rscript -e 'install.packages(c("latentFactoR", "geofi", " emmeans", "marginaleffects", "estimatr", "effectsize"))'
## tlverse-learnerit ja super-MICE-riippuvuuksia ymv.
  Rscript -e 'install.packages(c("speedglm", "Rsolnp", "nnls", "xgboost", "arm", "bartMachine", "earth", "forecast", "grf", "gbm", "h2o", "keras", "randomForest", "rugarch", "SuperLearner", "tsDyn", "lightgbm", "dbarts", "gam", "haldensify", "hts", "GA", "SIS", "partykit"))'
  Rscript -e 'install.packages(c("tableone", "R.rsp", "rgl", "rJava", "covr"))'
  Rscript -e 'install.packages(c("tmle", "txshift"))'
  Rscript -e 'install.packages(c("fastshap","shapviz"))'
  Rscript -e 'install.packages(c("mice", "extraTrees", "KernelKnn", "kernlab", "LogicReg", "party", "spls"))'
  Rscript -e 'install.packages(c("ltmle"))'

%help

  This is container for (mostly R) Apptainer environment of PsyTEAM research group from University of Helsinki.
